    {
      "cell_type": "code",
      "source": [
        "from scipy.optimize import linprog\n",
        "\n",
        "# Coeficientes de la función objetivo\n",
        "# Z = 5x1 + 3x2 + 6x3 + 4x4 + 7x5 + 2x6 + 8x7 + 3x8 + 4x9 + 5x10\n",
        "# linprog minimiza, por eso se ponen negativos\n",
        "c = [-5, -3, -6, -4, -7, -2, -8, -3, -4, -5]\n",
        "\n",
        "# Matriz de restricciones\n",
        "A = [\n",
        "    [2, 1, 3, 1, 2, 1, 2, 1, 1, 1],\n",
        "    [1, 2, 1, 2, 1, 3, 1, 2, 1, 1],\n",
        "    [3, 1, 2, 1, 3, 1, 2, 1, 2, 1]\n",
        "]\n",
        "\n",
        "print(\"Matriz A:\")\n",
        "for fila in A:\n",
        "    print(fila)"
      ],
